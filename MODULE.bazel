# Apple Command Line Tools SDK (MacOSX26.5.sdk): headers and .tbd linker
# stubs — text, no executable code once //internal:macos-sdk prunes the
# few legacy Mach-O leftovers. Served unauthenticated from Apple's
# softwareupdate CDN; the URL is one catalog product and can rot when
# Apple rotates generations (like the Alpine apks — bump URL + sha256
# from swscan.apple.com/content/catalogs/others/*.sucatalog, products
# whose Packages list a CLTools_macOSNMOS_SDK.pkg). NOTE: Apple's SDK
# license ties SDK *use* to Apple-branded hardware; building on a Linux
# VM hosted on a Mac satisfies that reading, other setups are the user's
# call — see README.
http_file(
    name = "macos_sdk_pkg",
    downloaded_file_path = "CLTools_macOSNMOS_SDK.pkg",
    sha256 = "debe353b27a13cd678b26ab216a040acf07b62c0639d8ac522df4ca07d121eb2",
    url = "https://swcdn.apple.com/content/downloads/33/19/140-17812-A_21ZLMMLY4E/zu3xwktttpoe71qiawhzgzvqss6rovawsa/CLTools_macOSNMOS_SDK.pkg",
)

