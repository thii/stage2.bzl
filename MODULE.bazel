    ],
)

# Alpine busybox-static packages (.apk files are tar.gz archives).
# Caveat: dl-cdn only serves the current -rN revision of an active branch,
# so this URL can rot when Alpine 3.22 bumps the package. If the fetch 404s,
# bump the version/sha256 here, or mirror the pinned apk somewhere durable
# and append that mirror to `urls` (the sha256 keeps any mirror honest).
http_archive(
    name = "busybox_linux_arm64",
    build_file_content = 'exports_files(["bin/busybox.static"])',
    sha256 = "ee469aee2958feffd7f64dd96655704025ff60af614f77a1d7323dc237c34da2",
    type = "tar.gz",
    urls = ["https://dl-cdn.alpinelinux.org/alpine/v3.22/main/aarch64/busybox-static-1.37.0-r20.apk"],
)

http_archive(
