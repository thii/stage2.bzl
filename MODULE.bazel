# gawk source: vanilla busybox awk miscompiles GCC's option tables (its
# regex handling of raw language names like "C++" in optc-gen.awk differs
# from gawk/mawk, silently dropping CL_CXX from options), so a real awk is
# built from source and put on PATH — GCC's configure prefers `gawk` by
# name. Alpine's busybox works only because Alpine patches it.
http_archive(
    name = "gawk_src",
    build_file_content = _SRC_TREE_BUILD,
    sha256 = "f8c3486509de705192138b00ef2c00bbbdd0e84c30d5c07d23fc73a9dc4cc9cc",
